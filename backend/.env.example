# Database
DATABASE_URL=postgresql+asyncpg://hiddenalerts:dev_password@localhost:5432/hiddenalerts
DATABASE_URL_SYNC=postgresql://hiddenalerts:dev_password@localhost:5432/hiddenalerts

# Application
APP_ENV=development
DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# Scheduler
SCHEDULER_ENABLED=true
SCHEDULER_INTERVAL_HOURS=6
DEFAULT_POLLING_MINUTES=60

# AI (Milestone 2)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Auth (Milestone 2+)
JWT_SECRET_KEY=change_me_to_a_random_secret_at_least_32_chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=43200

# Admin user seeding
ADMIN_EMAIL=ken@hiddenalerts.com
ADMIN_PASSWORD=change_me_before_running_migration

# Subscriber test user — optional, development only (Milestone 3)
# TEST_SUBSCRIBER_EMAIL=subscriber@example.com
# TEST_SUBSCRIBER_PASSWORD=change_me_test_password
# TEST_SUBSCRIBER_FULL_NAME=Test Subscriber

# Email alerts (Milestone 2+)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_smtp_password_here
ALERT_RECIPIENTS=recipient@example.com
