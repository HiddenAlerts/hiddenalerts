# ─── Database ─────────────────────────────────────────────────────────────────
# These three are read by the 'db' container to create the database.
# The DATABASE_URL uses 'hiddenalerts_db' (container name), not localhost.
POSTGRES_USER=hiddenalerts
POSTGRES_PASSWORD=CHANGE_TO_A_STRONG_PASSWORD
POSTGRES_DB=hiddenalerts

DATABASE_URL=postgresql+asyncpg://hiddenalerts:CHANGE_TO_A_STRONG_PASSWORD@hiddenalerts_db:5432/hiddenalerts
DATABASE_URL_SYNC=postgresql://hiddenalerts:CHANGE_TO_A_STRONG_PASSWORD@hiddenalerts_db:5432/hiddenalerts

# ─── Application ──────────────────────────────────────────────────────────────
APP_ENV=production
DEBUG=false
LOG_LEVEL=INFO

# ─── Scheduler ────────────────────────────────────────────────────────────────
SCHEDULER_ENABLED=true
SCHEDULER_INTERVAL_HOURS=6
DEFAULT_POLLING_MINUTES=60

# ─── AI — fill in for Milestone 2 ─────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ─── Email — fill in for Milestone 3 ──────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_RECIPIENTS=
